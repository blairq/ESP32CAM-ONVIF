CONFIG_FIRMWARE_VERSION="v1.4.0"

#
# Board Selection
#
CONFIG_BOARD_M5STACK_CAMERA=y
# CONFIG_BOARD_M5STACK_CAMERA is not set
# CONFIG_BOARD_M5STACK_PSRAM is not set
# CONFIG_BOARD_M5STACK_WIDE is not set
# CONFIG_BOARD_M5STACK_UNITCAM is not set
# CONFIG_BOARD_TTGO_T_CAMERA is not set
# CONFIG_BOARD_TTGO_T_JOURNAL is not set
# CONFIG_BOARD_WROVER_KIT is not set
# CONFIG_BOARD_ESP_EYE is not set
# CONFIG_BOARD_FREENOVE_ESP32S3 is not set
# CONFIG_BOARD_SEEED_XIAO_S3 is not set
# CONFIG_BOARD_ESP32S3_EYE is not set
# CONFIG_BOARD_ESP32P4_FUNCTION_EV is not set
# CONFIG_BOARD_ESP32P4_ETH is not set
# CONFIG_BOARD_CUSTOM is not set
# end of Board Selection

#
# Video Codec Selection
#
CONFIG_VIDEO_CODEC_MJPEG=y
# CONFIG_VIDEO_CODEC_H264 is not set
# end of Video Codec Selection

#
# Network Configuration
#
CONFIG_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"
CONFIG_AP_SSID="ESP32CAM-ONVIF"
CONFIG_AP_PASSWORD="esp32cam"
# CONFIG_STATIC_IP_ENABLED is not set
CONFIG_WEB_PORT=80
CONFIG_RTSP_PORT=554
CONFIG_ONVIF_PORT=8000
# end of Network Configuration

#
# Security & Authentication
#
CONFIG_WEB_USER="admin"
CONFIG_WEB_PASS="esp123"
# end of Security & Authentication

#
# Recording & Storage
#
# CONFIG_ENABLE_DAILY_RECORDING is not set
CONFIG_RECORD_SEGMENT_SEC=300
CONFIG_MAX_DISK_USAGE_PCT=90
# CONFIG_ENABLE_MOTION_DETECTION is not set
# end of Recording & Storage

#
# Hardware Features
#
CONFIG_FLASH_LED_ENABLED=y
# CONFIG_FLASH_LED_INVERT is not set
CONFIG_DEFAULT_AUTO_FLASH=y
CONFIG_STATUS_LED_ENABLED=y
CONFIG_STATUS_LED_INVERT=y
# CONFIG_PTZ_ENABLED is not set
# end of Hardware Features

#
# Bluetooth & Audio
#
# CONFIG_BLUETOOTH_ENABLED is not set
# end of Bluetooth & Audio

#
# ONVIF & NVR Settings
#
CONFIG_DEFAULT_ONVIF_ENABLED=y
CONFIG_DEVICE_MANUFACTURER="John-Varghese-EH"
CONFIG_DEVICE_MODEL="ESP32-CAM-ONVIF"
CONFIG_DEVICE_VERSION="1.3"
CONFIG_DEVICE_HARDWARE_ID="ESP32CAM-J0X"
CONFIG_GITHUB_REPO_OWNER="John-Varghese-EH"
CONFIG_GITHUB_REPO_NAME="ESP32CAM-ONVIF"
# end of ONVIF & NVR Settings

#
# MQTT & Home Assistant
#
# CONFIG_MQTT_ENABLED is not set
# end of MQTT & Home Assistant

#
# Advanced Settings
#
CONFIG_NTP_SERVER="pool.ntp.org"
CONFIG_GMT_OFFSET_SEC=19800
CONFIG_DAYLIGHT_OFFSET=0
CONFIG_DEBUG_MODE=y
CONFIG_DEBUG_LEVEL=2
# end of Advanced Settings
